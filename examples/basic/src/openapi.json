          {
            "name": "provider",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ]
      }
    },
    "/auth/callback": {
      "get": {
        "summary": "oauthCallback endpoint",
        "tags": [
