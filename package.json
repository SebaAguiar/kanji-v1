{
  "name": "kanji-v1",
  "version": "1.0.0",
  "description": "Backend framework for Bun with Hono, DI, native ORM, Auth and SDK generation",

  "private": true,
  "scripts": {
    "build": "pnpm -r build",
    "test": "rm -rf examples/*/dist && bun test",
    "test:ci": "rm -rf examples/*/dist && bun test",
    "lint": "eslint \"packages/**/src/**/*.ts\" \"examples/**/src/**/*.ts\"",
    "format": "prettier --write \"packages/**/*.ts\" \"examples/**/*.ts\"",
    "format:check": "prettier --check \"packages/**/*.ts\" \"examples/**/*.ts\"",
    "bump": "bun run scripts/bump-versions.ts --"
  },
  "keywords": [
    "hono",
    "bun",
    "orm",
    "auth",
    "sdk",
    "type-safe",
    "framework"
  ],
  "author": "David Sebastian Aguiar",
  "license": "MIT",
  "packageManager": "pnpm@10.28.0",
  "devDependencies": {
    "bun-types": "1.3.14",
    "eslint": "10.6.0",
    "prettier": "3.9.4",
    "reflect-metadata": "^0.2.2",
    "typescript": "6.0.3",
    "zod": "^3.24.1"
  }
}
